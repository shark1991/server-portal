# Server Portal Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3000
SESSION_SECRET=your-super-secret-session-key-change-this
NODE_ENV=production

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your-mysql-password
DB_NAME=server_portal

# Plex OAuth (get from https://www.plex.tv/claim)
PLEX_CLIENT_ID=your-plex-client-id
PLEX_CLIENT_SECRET=your-plex-client-secret
PLEX_REDIRECT_URL=http://portal.eakin.cloud/auth/plex/callback

# Service URLs (optional - defaults to local)
PLEX_SERVER_URL=http://localhost:32400
OVERSEERR_URL=http://localhost:5055
NEXTCLOUD_URL=http://localhost:8080

# Email (for signup notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=eakinben@gmail.com
SMTP_PASS=your-app-password
ADMIN_EMAIL=eakinben@gmail.com
ADMIN_URL=http://portal.eakin.cloud/admin